{
    "manifest_version": 3,
    "name": "WAPI Runtime",
    "version": "0.1.0",
    "description": "Global browser shim for WAPI (WebAssembly Platform Interface). Exposes window.WAPI on every page so apps don't have to bundle the shim.",
    "minimum_chrome_version": "111",
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["wapi_shim.js", "ready.js"],
            "run_at": "document_start",
            "all_frames": true,
            "world": "MAIN"
        },
        {
            "matches": ["<all_urls>"],
            "js": ["bridge.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "background": {
        "service_worker": "sw.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "WAPI Modules"
    },
    "permissions": [],
    "host_permissions": []
}
